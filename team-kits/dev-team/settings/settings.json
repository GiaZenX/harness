{
  "agent": "project-manager",
  "model": "opus",
  "plansDirectory": "./plans",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(npm *)",
      "Bash(node *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.key)",
      "Read(**/*.pem)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_status.py\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_no_adhoc.py\"" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_pm_scope.py\"" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gate_git.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gate_test_coverage.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gate_memory_complete.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gate_packaging_decision.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/gate_pipeline.py\"", "timeout": 1800 }
        ]
      },
      {
        "matcher": "Agent|Task",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_agent_spawn.py\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/auto_dashboard.py\"" }
        ]
      }
    ]
  }
}
